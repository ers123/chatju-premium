# ChatJu Premium - Environment Variables Template
# Copy this file to .env and fill in your actual credentials

# Node Environment
NODE_ENV=development

# AI Provider Configuration
# AI_PROVIDER: openai (default), claude, or gemini
# Fallback order: openai → claude → gemini
AI_PROVIDER=openai

# OpenAI API Key (Primary — GPT-5.2)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-openai-api-key-here

# Anthropic Claude API Key (Fallback 1 — Claude Sonnet 4.6)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Google Gemini API Key (Fallback 2 — Gemini 3 Flash)
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Supabase Configuration
# Get from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# PayPal (Payment Gateway - Level 7)
# Get from: https://developer.paypal.com/dashboard
# Use sandbox credentials for development, live for production
PAYPAL_CLIENT_ID=your-paypal-client-id-here
PAYPAL_CLIENT_SECRET=your-paypal-client-secret-here
PAYPAL_API_BASE_URL=https://api-m.sandbox.paypal.com
PAYPAL_WEBHOOK_ID=your-paypal-webhook-id-here

# Frontend URL (for payment redirects - Level 7)
FRONTEND_URL=https://somyung.pages.dev

# Optional: Server Port (for local development)
# PORT=3000
